@{
    ViewData["Title"] = "Menu - Corie";
}

<!-- Header Menu -->
<div style="text-align: center; padding: 60px 20px 40px 20px;">
    <h1 style="font-family: 'Playfair Display', serif; font-size: 2.5em; color: #1a1a1a;">Notre Menu</h1>
    <p style="color: #888; letter-spacing: 3px; text-transform: uppercase; font-size: 0.9em;">Cuisine Africaine Authentique</p>
    <div style="width: 60px; height: 2px; background-color: #D4AF37; margin: 20px auto;"></div>
</div>

<!-- Plats principaux -->
<div style="max-width: 700px; margin: auto; padding: 20px;">
    <h2 style="font-family: 'Playfair Display', serif; color: #1a1a1a; letter-spacing: 2px; text-transform: uppercase; font-size: 1.1em; margin-bottom: 30px;">Plats principaux</h2>

    <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-bottom: 1px solid #eee;">
        <details>
            <summary style="font-size: 1.1em; cursor: pointer; font-family: 'Playfair Display', serif;">Thiéboudienne</summary>
            <p style="color: #888; font-size: 0.9em; margin-top: 8px;">Ingrédients à venir...</p>
        </details>
        <span style="color: #D4AF37; font-weight: bold; font-size: 1.1em;">12€</span>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-bottom: 1px solid #eee;">
        <details>
            <summary style="font-size: 1.1em; cursor: pointer; font-family: 'Playfair Display', serif;">Poulet Yassa</summary>
            <p style="color: #888; font-size: 0.9em; margin-top: 8px;">Ingrédients à venir...</p>
        </details>
        <span style="color: #D4AF37; font-weight: bold; font-size: 1.1em;">11€</span>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-bottom: 1px solid #eee;">
        <details>
            <summary style="font-size: 1.1em; cursor: pointer; font-family: 'Playfair Display', serif;">Ndolé</summary>
            <p style="color: #888; font-size: 0.9em; margin-top: 8px;">Ingrédients à venir...</p>
        </details>
        <span style="color: #D4AF37; font-weight: bold; font-size: 1.1em;">11€</span>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-bottom: 1px solid #eee;">
        <details>
            <summary style="font-size: 1.1em; cursor: pointer; font-family: 'Playfair Display', serif;">Mafé</summary>
            <p style="color: #888; font-size: 0.9em; margin-top: 8px;">Ingrédients à venir...</p>
        </details>
        <span style="color: #D4AF37; font-weight: bold; font-size: 1.1em;">13€</span>
    </div>

    <!-- Boissons -->
    <h2 style="font-family: 'Playfair Display', serif; color: #1a1a1a; letter-spacing: 2px; text-transform: uppercase; font-size: 1.1em; margin: 40px 0 30px 0;">Boissons</h2>

    <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-bottom: 1px solid #eee;">
        <span style="font-size: 1.1em; font-family: 'Playfair Display', serif;">Bissap</span>
        <span style="color: #D4AF37; font-weight: bold; font-size: 1.1em;">3€</span>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0; border-bottom: 1px solid #eee;">
        <span style="font-size: 1.1em; font-family: 'Playfair Display', serif;">Gingembre</span>
        <span style="color: #D4AF37; font-weight: bold; font-size: 1.1em;">3€</span>
    </div>
</div>

<div style="text-align: center; padding: 60px 20px;">
    <a href="/Home/Contact" style="border: 1px solid #1a1a1a; color: #1a1a1a; padding: 12px 40px;
    text-decoration: none; letter-spacing: 2px; text-transform: uppercase; font-size: 0.9em;">Nous contacter</a>
</div>