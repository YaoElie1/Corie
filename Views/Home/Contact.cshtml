@{
    ViewData["Title"] = "Contact - Corie";
}

<!-- Header -->
<div style="text-align: center; padding: 60px 20px 40px 20px;">
    <h1 style="font-family: 'Playfair Display', serif; font-size: 2.5em; color: #1a1a1a;">Nous Trouver</h1>
    <p style="color: #888; letter-spacing: 3px; text-transform: uppercase; font-size: 0.9em;">Venez nous rendre visite</p>
    <div style="width: 60px; height: 2px; background-color: #D4AF37; margin: 20px auto;"></div>
</div>

<div style="max-width: 600px; margin: auto; padding: 20px;">

    <!-- Adresse -->
    <div style="padding: 30px 0; border-bottom: 1px solid #eee;">
        <h3 style="font-family: 'Playfair Display', serif; letter-spacing: 2px; text-transform: uppercase; font-size: 0.9em; color: #888; margin-bottom: 15px;">📍 Adresse</h3>
        <p style="font-size: 1.2em; color: #1a1a1a;">Mouscron , 7712</p>
    </div>

    <!-- Horaires -->
    <div style="padding: 30px 0; border-bottom: 1px solid #eee;">
        <h3 style="font-family: 'Playfair Display', serif; letter-spacing: 2px; text-transform: uppercase; font-size: 0.9em; color: #888; margin-bottom: 15px;">🕐 Horaires</h3>
        <div style="display: flex; justify-content: space-between; padding: 8px 0;">
            <span style="color: #555;">Lundi — Vendredi</span>
            <span style="color: #1a1a1a; font-weight: bold;">08h — 20h</span>
        </div>
        <div style="display: flex; justify-content: space-between; padding: 8px 0;">
            <span style="color: #555;">Samedi — Dimanche</span>
            <span style="color: #D4AF37; font-weight: bold;">Fermé</span>
        </div>
    </div>

    <!-- Téléphone -->
    <div style="padding: 30px 0;">
        <h3 style="font-family: 'Playfair Display', serif; letter-spacing: 2px; text-transform: uppercase; font-size: 0.9em; color: #888; margin-bottom: 15px;">📞 Téléphone</h3>
        <p style="font-size: 1.2em; color: #1a1a1a;">Numéro à venir</p>
    </div>

</div>

<div style="text-align: center; padding: 60px 20px;">
    <a href="/" style="border: 1px solid #1a1a1a; color: #1a1a1a; padding: 12px 40px;
    text-decoration: none; letter-spacing: 2px; text-transform: uppercase; font-size: 0.9em;">Retour à l'accueil</a>
</div>